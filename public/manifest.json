{
  "manifest_version": 3,
  "name": "TradeDesk",
  "version": "0.1.0",
  "description": "Intelligence layer HUD for day traders",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*",
    "http://localhost:3001/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://localhost:3001 ws://localhost:3001;"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open TradeDesk"
  }
}
